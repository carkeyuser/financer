POSTGRES_USER=financeuser
POSTGRES_PASSWORD=changeme_sicher
POSTGRES_DB=finance

DATABASE_URL=postgresql://financeuser:changeme_sicher@db:5432/finance

# Generieren mit: openssl rand -base64 32
NEXTAUTH_SECRET=aendern_bitte_generieren

NEXTAUTH_URL=http://localhost:3000

# Set to false on hosts without outbound HTTPS to api.nasdaq.com (e.g. locked-down LXC)
# MARKET_CALENDAR_EXTERNAL=false

# Deploy mode on the server: build (default) or ghcr
# build — git pull + docker compose up -d --build (local image from repo)
# ghcr    — docker compose pull + up -d (pre-built image from GHCR)
# FINANCER_DEPLOY_MODE=build
# FINANCER_IMAGE=ghcr.io/carkeyuser/financer:latest
