POSTGRES_USER=financeuser
POSTGRES_PASSWORD=changeme_sicher
POSTGRES_DB=finance

# Local dev (npm run dev + prisma on host): use localhost after `npm run db:up`
DATABASE_URL=postgresql://financeuser:changeme_sicher@localhost:5432/finance
# Docker app container only:
# DATABASE_URL=postgresql://financeuser:changeme_sicher@db:5432/finance

# Generieren mit: openssl rand -base64 32
NEXTAUTH_SECRET=aendern_bitte_generieren

NEXTAUTH_URL=http://localhost:3001
AUTH_TRUST_HOST=true

# Public registration (default: enabled). Set to false in production.
# ALLOW_REGISTRATION=false

# Demo seed password (optional; default demo1234 with console warning if unset)
# SEED_DEMO_PASSWORD=
# Force demo password/2FA reset when re-seeding in production (default: skip in production)
# SEED_RESET_DEMO=true

# Set to false on hosts without outbound HTTPS to api.nasdaq.com (e.g. restricted network)
# MARKET_CALENDAR_EXTERNAL=false

# Deploy mode on the server: build (default) or ghcr
# build — git pull + docker compose up -d --build (local image from repo)
# ghcr    — docker compose pull + up -d (pre-built image from GHCR)
# FINANCER_DEPLOY_MODE=build
# FINANCER_IMAGE=ghcr.io/carkeyuser/financer:latest

# Optional on server: shorten manual updates (see plan/deploy.md)
# FINANCER_DEPLOY_MODE=ghcr
# COMPOSE_FILE=docker-compose.yml:docker-compose.prod.yml:docker-compose.update.yml

# In-app update from /settings (F-46) — opt-in; update.sh adds docker-compose.update.yml when enabled
# FINANCER_UPDATE_ENABLED=true
# FINANCER_HOST_APP_DIR=/opt/financer
# FINANCER_DOCKER_GID=999
# FINANCER_HOST_MOUNT is set automatically in docker-compose.update.yml (same as FINANCER_HOST_APP_DIR on the host)
# COMPOSE_PROJECT_NAME=financer
